# ==========================================
# NexusAI Backend — Environment Variables
# Copy this to .env and fill in your values.
# ==========================================

# --- App ---
APP_ENV=development
APP_NAME=NexusAI
DEBUG=true
SECRET_KEY=your-secret-key-here

# --- Database (SQLite — no server needed) ---
SQLITE_PATH=nexusai.db
LANGGRAPH_CHECKPOINT_DB=nexusai_checkpoints.db

# --- FAISS & Local Storage ---
FAISS_INDEX_DIR=faiss_indexes
UPLOAD_DIR=uploads

# --- JWT Auth ---
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Groq API (FREE TIER — Required) ---
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_REASONING=deepseek-r1-distill-llama-70b

# --- LangSmith Observability (Optional, Free Tier) ---
# Sign up at: https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=nexusai-development

# --- Web Search ---
# DuckDuckGo is used by default (free, no API key needed)
# Set USE_TAVILY=true and add TAVILY_API_KEY if you have a Tavily account
USE_TAVILY=false
TAVILY_API_KEY=

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
FRONTEND_URL=http://localhost:3000

# --- Rate Limiting (in-memory, no Redis needed) ---
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# --- MCP ---
MCP_CONFIG_PATH=mcp_config.json
MCP_TIMEOUT=30

# --- Memory System ---
MEMORY_MAX_RESULTS=5
MEMORY_SIMILARITY_THRESHOLD=0.3

# --- Reflection ---
REFLECTION_SCORE_THRESHOLD=0.7
REFLECTION_MAX_RETRIES=2
